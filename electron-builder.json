{
    "appId": "com.jawsdevelopers.mailcowclient",
    "files": ["dist-electron", "dist-react"],
    "productName": "Mailcow Client",
    "extraResources": ["dist-electron/preload.cjs"],
    "icon": "./desktopIcon.png",
    "publish": [
        {
            "provider": "github",
            "owner": "JAWS-Developers-Opensource",
            "repo": "MailcowClient"
        }
    ],
    "mac": {
        "target": "dmg"
    },
    "linux": {
        "target": "AppImage",
        "category": "Utility"
    },
    "win": {
        "target": ["portable", "msi"]
    }
}